FROM nvidia/cuda:12.6.3-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1
ENV HF_MODEL_DIR=/repository
ENV QWEN_TTS_MODEL=/repository
ENV QWEN_TTS_MAX_PENDING=8
ENV QWEN_TTS_CHUNK_SIZE=12
ENV HOME=/tmp
ENV TORCHINDUCTOR_CACHE_DIR=/tmp/torch_inductor

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    ffmpeg libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . /app

RUN python3 -m pip install --upgrade pip \
    && python3 -m pip install --index-url https://download.pytorch.org/whl/cu126 torch torchaudio \
    && python3 -m pip install ".[demo]" pydub

EXPOSE 80

CMD ["python3", "examples/openai_server.py", "--host", "0.0.0.0", "--port", "80"]
